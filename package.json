{
  "name": "cli-cockpit",
  "productName": "CLI Cockpit Next",
  "version": "2.0.0",
  "description": "Claude CLI Analytics & Control Platform",
  "main": ".vite/build/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "electron-forge start",
    "start:debug": "DEBUG=true electron-forge start",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform=darwin",
    "build:mac": "electron-forge make --platform=darwin",
    "build": "npm run build:mac",
    "make": "npm run build:mac",
    "publish": "electron-forge publish",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:skills": "vitest run src/pages/SkillsPage.test.tsx src/lib/maintenanceRegistryValidation.test.ts src/lib/jsonAstPathLocator.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [],
  "author": {
    "name": "mineclover",
    "email": "mineclover@naver.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.18.12",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.0.18",
    "electron": "^38.4.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.2",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.45",
    "@anthropic-ai/claude-agent-sdk": "^0.1.25",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@langchain/core": "^1.0.6",
    "@langchain/langgraph": "^1.0.2",
    "@packages/ai-sdk-cli": "file:../ai-sdk-cli",
    "@standard-schema/spec": "^1.0.0",
    "ai": "^6.0.91",
    "dexie": "^4.2.1",
    "electron-squirrel-startup": "^1.0.1",
    "gray-matter": "^4.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.4",
    "reactflow": "^11.11.4",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  }
}
