{
  "name": "cli-cockpit",
  "productName": "CLI Cockpit Next",
  "version": "2.0.0",
  "description": "Claude CLI Analytics & Control Platform",
  "main": ".vite/build/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "electron-forge start",
    "start:debug": "DEBUG=true electron-forge start",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform=darwin",
    "build:mac": "electron-forge make --platform=darwin",
    "build": "npm run build:mac",
    "make": "npm run build:mac",
    "publish": "electron-forge publish",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:skills": "vitest run src/pages/CliMaintenancePage.test.tsx src/lib/maintenanceRegistryValidation.test.ts src/lib/jsonAstPathLocator.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "cli": "tsx src/cli/index.ts"
  },
  "keywords": [],
  "author": {
    "name": "mineclover",
    "email": "mineclover@naver.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.4",
    "electron": "^41.2.1",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@packages/ai-sdk-cli": "file:../ai-sdk-cli",
    "@standard-schema/spec": "^1.0.0",
    "ai": "^6.0.168",
    "dexie": "^4.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "reactflow": "^11.11.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
